{
  "version": 1,
  "description": "Endpoint detection factory line — mini-repo cases (full index) plus optional cloned OSS repos.",
  "miniRepos": [
    "tsoa-ssh",
    "tsoa-get",
    "next-health",
    "next-signup",
    "next-posts",
    "next-endpoint-scope",
    "django-users",
    "nestjs-novu-widgets",
    "fastify-user-routes"
  ],
  "repos": [
    {
      "id": "express",
      "url": "https://github.com/expressjs/express.git",
      "shallow": true,
      "minRoutes": 1,
      "optional": true,
      "note": "Stock Express resolver smoke — enable with FACTORY_LINE_CLONE=1"
    },
    {
      "id": "fastify-typescript",
      "url": "https://github.com/hmake98/fastify-typescript.git",
      "shallow": true,
      "minRoutes": 4,
      "optional": true,
      "note": "Fastify shorthand + register prefix — enable with FACTORY_LINE_CLONE=1"
    }
  ]
}
