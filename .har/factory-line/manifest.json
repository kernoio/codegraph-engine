{
  "version": 1,
  "description": "Endpoint detection factory line — mini-repo cases (full index) plus optional cloned OSS repos.",
  "miniRepos": [
    "tsoa-ssh",
    "tsoa-get",
    "next-health",
    "next-signup",
    "next-posts",
    "next-endpoint-scope",
    "django-users",
    "nestjs-novu-widgets",
    "akka-http-users"
  ],
  "repos": [
    {
      "id": "express",
      "url": "https://github.com/expressjs/express.git",
      "shallow": true,
      "minRoutes": 1,
      "optional": true,
      "note": "Stock Express resolver smoke — enable with FACTORY_LINE_CLONE=1"
    },
    {
      "id": "akka-http-microservice",
      "url": "https://github.com/theiterators/akka-http-microservice.git",
      "shallow": true,
      "minRoutes": 2,
      "optional": true,
      "note": "Akka HTTP microservice sample — enable with FACTORY_LINE_CLONE=1"
    }
  ]
}
