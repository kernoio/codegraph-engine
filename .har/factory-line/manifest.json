{
  "version": 1,
  "description": "Endpoint detection factory line \u2014 mini-repo cases (full index) plus optional cloned OSS repos.",
  "miniRepos": [
    "tsoa-ssh",
    "tsoa-get",
    "next-health",
    "next-signup",
    "next-posts",
    "next-endpoint-scope",
    "django-users",
    "nestjs-novu-widgets",
    "fiber-auth-jwt",
    "hono-blog",
    "ktor-widgets",
    "sinatra-pizzerias",
    "grape-statuses",
    "symfony-blog",
    "fastify-user-routes"
  ],
  "repos": [
    {
      "id": "express",
      "url": "https://github.com/expressjs/express.git",
      "shallow": true,
      "minRoutes": 1,
      "optional": true,
      "note": "Stock Express resolver smoke \u2014 enable with FACTORY_LINE_CLONE=1"
    },
    {
      "id": "gofiber-boilerplate",
      "url": "https://github.com/gofiber/boilerplate.git",
      "shallow": true,
      "minRoutes": 2,
      "optional": true,
      "note": "Fiber Group routes in app.go \u2014 enable with FACTORY_LINE_CLONE=1"
    },
    {
      "id": "hono-examples",
      "url": "https://github.com/honojs/examples.git",
      "shallow": true,
      "minRoutes": 5,
      "optional": true,
      "note": "Hono official examples \u2014 enable with FACTORY_LINE_CLONE=1"
    },
    {
      "id": "ktor-exposed-starter",
      "url": "https://github.com/raharrison/kotlin-ktor-exposed-starter.git",
      "shallow": true,
      "minRoutes": 5,
      "optional": true,
      "note": "Ktor routing DSL \u2014 enable with FACTORY_LINE_CLONE=1"
    },
    {
      "id": "grape-on-rack",
      "url": "https://github.com/ruby-grape/grape-on-rack.git",
      "shallow": true,
      "minRoutes": 5,
      "optional": true,
      "note": "Grape mount/prefix smoke \u2014 enable with FACTORY_LINE_CLONE=1"
    },
    {
      "id": "symfony-demo",
      "url": "https://github.com/symfony/demo.git",
      "shallow": true,
      "minRoutes": 5,
      "optional": true,
      "note": "Symfony attribute routes \u2014 enable with FACTORY_LINE_CLONE=1"
    },
    {
      "id": "fastify-typescript",
      "url": "https://github.com/hmake98/fastify-typescript.git",
      "shallow": true,
      "minRoutes": 4,
      "optional": true,
      "note": "Fastify shorthand + register prefix \u2014 enable with FACTORY_LINE_CLONE=1"
    }
  ]
}
