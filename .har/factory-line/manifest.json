{
  "version": 1,
  "description": "Endpoint detection factory line — mini-repo cases (full index) plus optional cloned OSS repos.",
  "miniRepos": [
    "tsoa-ssh",
    "tsoa-get",
    "next-health",
    "next-signup",
    "next-posts",
    "next-endpoint-scope",
    "django-users",
    "nestjs-novu-widgets",
    "tornado-string-service"
  ],
  "repos": [
    {
      "id": "express",
      "url": "https://github.com/expressjs/express.git",
      "shallow": true,
      "minRoutes": 1,
      "optional": true,
      "note": "Stock Express resolver smoke — enable with FACTORY_LINE_CLONE=1"
    },
    {
      "id": "webssh",
      "url": "https://github.com/huashengdun/webssh.git",
      "shallow": true,
      "minRoutes": 2,
      "optional": true,
      "note": "Tornado Application handlers — enable with FACTORY_LINE_CLONE=1"
    }
  ]
}
