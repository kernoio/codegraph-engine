{
  "version": 1,
  "description": "Endpoint detection factory line — mini-repo cases (full index) plus optional cloned OSS repos.",
  "miniRepos": [
    "tsoa-ssh",
    "tsoa-get",
    "next-health",
    "next-signup",
    "next-posts",
    "next-endpoint-scope",
    "django-users",
    "nestjs-novu-widgets",
    "adonisjs-learn"
  ],
  "repos": [
    {
      "id": "express",
      "url": "https://github.com/expressjs/express.git",
      "shallow": true,
      "minRoutes": 1,
      "optional": true,
      "note": "Stock Express resolver smoke — enable with FACTORY_LINE_CLONE=1"
    },
    {
      "id": "lets-learn-adonisjs-6",
      "url": "https://github.com/adocasts/lets-learn-adonisjs-6.git",
      "shallow": true,
      "minRoutes": 10,
      "optional": true,
      "note": "AdonisJS v6 routes — enable with FACTORY_LINE_CLONE=1"
    }
  ]
}
