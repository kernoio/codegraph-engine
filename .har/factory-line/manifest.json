{
  "version": 1,
  "description": "Endpoint detection factory line — mini-repo cases (full index) plus optional cloned OSS repos.",
  "miniRepos": [
    "tsoa-ssh",
    "tsoa-get",
    "next-health",
    "next-signup",
    "next-posts",
    "next-endpoint-scope",
    "django-users",
    "nestjs-novu-widgets",
    "http4s-todo"
  ],
  "repos": [
    {
      "id": "express",
      "url": "https://github.com/expressjs/express.git",
      "shallow": true,
      "minRoutes": 1,
      "optional": true,
      "note": "Stock Express resolver smoke — enable with FACTORY_LINE_CLONE=1"
    },
    {
      "id": "todo-http4s-doobie",
      "url": "https://github.com/jaspervz/todo-http4s-doobie.git",
      "shallow": true,
      "minRoutes": 5,
      "optional": true,
      "note": "http4s DSL TodoService — enable with FACTORY_LINE_CLONE=1"
    }
  ]
}
