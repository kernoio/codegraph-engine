{
  "version": 1,
  "description": "Endpoint detection factory line — mini-repo cases (full index) plus optional cloned OSS repos.",
  "miniRepos": [
    "tsoa-ssh",
    "tsoa-get",
    "next-health",
    "next-signup",
    "next-posts",
    "next-endpoint-scope",
    "django-users",
    "nestjs-novu-widgets",
    "vertx-simple-rest"
  ],
  "repos": [
    {
      "id": "express",
      "url": "https://github.com/expressjs/express.git",
      "shallow": true,
      "minRoutes": 1,
      "optional": true,
      "note": "Stock Express resolver smoke — enable with FACTORY_LINE_CLONE=1"
    },
    {
      "id": "vertx-examples",
      "url": "https://github.com/vert-x3/vertx-examples.git",
      "shallow": true,
      "minRoutes": 3,
      "optional": true,
      "note": "Vert.x Web SimpleREST + siblings — enable with FACTORY_LINE_CLONE=1"
    }
  ]
}
