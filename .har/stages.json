{
  "version": "1",
  "artifactsDir": "artifacts",
  "logsDir": "logs",
  "agentSlots": {
    "min": 1,
    "max": 10
  },
  "verificationStages": [
    "factory-line"
  ],
  "stages": [
    {
      "id": "setup-infra",
      "kind": "setup",
      "description": "Optional shared Docker infrastructure",
      "command": "./.har/setup-infra.sh"
    },
    {
      "id": "launch",
      "kind": "launch",
      "description": "Prepare agent slot (git worktree, deps, env file)",
      "command": "./.har/launch.sh {agentId}",
      "artifacts": [
        {
          "path": ".env.agent.{agentId}",
          "kind": "file",
          "description": "Generated per-agent environment file in the session work dir"
        }
      ]
    },
    {
      "id": "verify",
      "kind": "verify",
      "description": "Verification pipeline (quick smoke by default; --full runs the registry's verificationStages: factory-line)",
      "command": "./.har/verify.sh {agentId}",
      "artifacts": [
        {
          "path": ".har/artifacts",
          "kind": "directory",
          "description": "Optional verification outputs"
        }
      ],
      "acceptsArgs": [
        "--full"
      ]
    },
    {
      "id": "status",
      "kind": "inspect",
      "description": "Inspect agent slot status and worktree path",
      "command": "./.har/agent-cli.sh {agentId} status",
      "artifacts": [
        {
          "path": ".har/logs",
          "kind": "directory",
          "description": "Optional harness logs"
        }
      ]
    },
    {
      "id": "teardown",
      "kind": "teardown",
      "description": "Remove worktree and env file for the slot",
      "command": "./.har/teardown.sh {agentId}"
    },
    {
      "id": "factory-line",
      "kind": "test",
      "description": "Endpoint detection e2e across fixture repos",
      "script": "stages/factory-line.sh",
      "artifacts": [
        {
          "path": ".har/artifacts/factory-line",
          "kind": "directory",
          "description": "Artifacts for the factory-line stage"
        }
      ],
      "requiresAgentId": true
    }
  ]
}
